rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // -- Global Helpers --
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['userId', 'name', 'grade', 'createdAt', 'updatedAt']) 
        && data.keys().size() == 5
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.grade is string && data.grade.size() <= 100;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['userId', 'title', 'subject', 'dueDate', 'estimatedTime', 'priority', 'completed', 'createdAt', 'updatedAt'])
        && data.keys().size() == 9
        && data.userId == request.auth.uid
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.subject is string && data.subject.size() <= 100
        && data.dueDate is string && data.dueDate.size() <= 20
        && data.estimatedTime is number && data.estimatedTime > 0
        && data.priority is string && data.priority in ['Low', 'Medium', 'High']
        && data.completed is bool;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
      allow list: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn() 
        && isValidId(userId)
        && request.auth.uid == userId
        && isValidUserProfile(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
      
      allow update: if isSignedIn()
        && isValidId(userId)
        && request.auth.uid == userId
        && existing().userId == request.auth.uid
        && isValidUserProfile(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().userId == existing().userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'grade', 'updatedAt']);

      allow delete: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && existing().userId == request.auth.uid;

      match /tasks/{taskId} {
        allow get: if isSignedIn() && isValidId(userId) && isValidId(taskId) && request.auth.uid == userId;
        allow list: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && resource.data.userId == request.auth.uid;

        allow create: if isSignedIn() 
          && isValidId(userId)
          && isValidId(taskId)
          && request.auth.uid == userId
          && isValidTask(incoming())
          && incoming().createdAt == request.time
          && incoming().updatedAt == request.time;

        allow update: if isSignedIn()
          && isValidId(userId)
          && isValidId(taskId)
          && request.auth.uid == userId
          && existing().userId == request.auth.uid
          && isValidTask(incoming())
          && incoming().createdAt == existing().createdAt
          && incoming().updatedAt == request.time
          && incoming().userId == existing().userId
          && (
            (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'subject', 'dueDate', 'estimatedTime', 'priority', 'completed', 'updatedAt'])) ||
            (incoming().diff(existing()).affectedKeys().hasOnly(['completed', 'updatedAt'])) ||
            (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'subject', 'dueDate', 'estimatedTime', 'priority', 'updatedAt']))
          );
        
        allow delete: if isSignedIn() 
          && isValidId(userId) 
          && isValidId(taskId) 
          && request.auth.uid == userId 
          && existing().userId == request.auth.uid;
      }
    }
  }
}
