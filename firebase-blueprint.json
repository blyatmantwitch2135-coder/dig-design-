{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile containing name and grade.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "grade": { "type": "string" },
        "createdAt": { "type": "string", "format": "timestamp" },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["userId", "name", "createdAt", "updatedAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A student task.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "dueDate": { "type": "string" },
        "estimatedTime": { "type": "number" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "timestamp" },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["userId", "title", "subject", "dueDate", "estimatedTime", "priority", "completed", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profiles."
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Stores tasks for a specific user."
    }
  }
}
